#!/bin/bash
# Install agentlet in Harbor benchmark container
set -e

echo "Installing agentlet..."

# Install Python dependencies
pip install --quiet rich prompt-toolkit pygments

# Copy agentlet source to container
mkdir -p /opt/agentlet
cp -r {{ agentlet_source_path }}/* /opt/agentlet/

# Install agentlet in editable mode
pip install --quiet -e /opt/agentlet

# Create benchmark runner entry point
chmod +x /opt/agentlet/agentlet/benchmark/benchmark_runner.py

# Verify installation
python -c "import agentlet; print('agentlet installed successfully')"

echo "Installation complete"
